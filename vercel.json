{
  "framework": "nextjs",
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "www.pawcities.com" }],
      "destination": "https://pawcities.com/:path",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/social-post",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/refresh-photos",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/social-engagement",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/social-outreach",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/health-check",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/event-discovery",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/marketing-digest",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/process-ingest",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/event-post",
      "schedule": "0 18 * * *"
    },
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 15 * * 0"
    }
  ]
}
