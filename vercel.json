{
  "framework": "nextjs",
  "redirects": [
    {
      "source": "/:path(.*)",
      "has": [{ "type": "host", "value": "www.pawcities.com" }],
      "destination": "https://pawcities.com/:path",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/social-post?secret=${CRON_SECRET}",
      "schedule": "0 14 * * 1,3,5"
    },
    {
      "path": "/api/cron/refresh-photos?secret=${CRON_SECRET}",
      "schedule": "0 6 * * 0"
    },
    {
      "path": "/api/cron/social-engagement?secret=${CRON_SECRET}",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/social-outreach?secret=${CRON_SECRET}",
      "schedule": "0 11 * * *"
    }
  ]
}
